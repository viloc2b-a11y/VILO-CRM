# =============================================================================
# Supabase (Project Settings → API)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
# Solo servidor (webhooks, agentes, bypass RLS). Nunca expongas esto al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# =============================================================================
# Square (HazloAsíYa — webhooks + API opcional)
# =============================================================================
# Developer Dashboard → Webhooks → Signature key del subscription
SQUARE_WEBHOOK_SIGNATURE_KEY=sq0sig_xxxxx
# Debe coincidir CARACTER POR CARACTER con la Notification URL del dashboard (sin query)
SQUARE_WEBHOOK_NOTIFICATION_URL=https://YOUR_DOMAIN/api/hazlo/square/webhook
# Opcional: llamadas REST a Square (no requeridas solo para el webhook)
SQUARE_ACCESS_TOKEN=EAAAlxxxxx
SQUARE_APPLICATION_ID=sq0idp-xxxxx

# Eventos recomendados en el dashboard: payment.created, payment.updated; opcional refund.*
# (Los fallos suelen venir como payment.updated con payment.status = FAILED.)

# =============================================================================
# Cron / seguridad (POST /tick y similares: header x-cron-secret cuando CRON_SECRET está definido)
# =============================================================================
CRON_SECRET=tu_secreto_para_crons
# Opcional: POST /api/vilo/intake-b2b — header x-vilo-api-secret debe coincidir si definís esta variable
# VILO_API_SECRET=vilo_b2b_api_key_xxx

# =============================================================================
# Notificaciones — Resend + Twilio (recovery/growth Hazlo, Vitalis, validator)
# =============================================================================
RESEND_API_KEY=re_xxxxx
RESEND_FROM="Vilo CRM <onboarding@resend.dev>"
# Webhook POST /api/vilo/email-tracking — misma cabecera que configures en Resend (x-resend-secret o x-webhook-secret)
# RESEND_WEBHOOK_SECRET=
# Alias opcional leído por lib/notifications/dispatcher.ts si RESEND_FROM está vacío
# EMAIL_FROM="ViloOS <notificaciones@tudominio.com>"
# Bus unificado Email + Slack (`lib/notifications/send-unified-alert.ts`, idempotente en `notification_deliveries`)
# ALERTS_EMAIL_TO=ops@vilo.example
# ALERTS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
# Webhook solo para alertas críticas (POST /api/notifications/tick-critical); si vacío, reusa ALERTS_SLACK_WEBHOOK_URL
# SLACK_CRITICAL_WEBHOOK=
# Webhook para “reporte listo” (POST /api/notifications/report-ready); si vacío, reusa ALERTS_SLACK_WEBHOOK_URL
# SLACK_OPS_WEBHOOK=
# Twilio: recovery (voz/SMS), growth (SMS), Vitalis scheduler (voz). Ajustá según producto.
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
# Número E.164 para llamadas / SMS (p. ej. recovery día 5)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# SMS growth (si distinto del anterior)
# TWILIO_SMS_NUMBER=
# Prefijo país para normalizar móviles (default +52)
# TWILIO_E164_PREFIX=+52
# Sandbox WhatsApp de Twilio (formato whatsapp:+1…); el código actual usa Cloud API / SMS según módulo.
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# URLs TwiML (opcional)
# TWILIO_REMINDER_TWIML_URL=
# HAZLO_RECOVERY_TWIML_URL=

# WhatsApp Cloud API (Vitalis intake + opcional Hazlo Recovery/Growth por plantillas Meta)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# Webhook inbound: GET verify (si vacío, se usa META_INTAKE_VERIFY_TOKEN) + POST firma META_APP_SECRET
# WHATSAPP_VERIFY_TOKEN=
# Plantillas aprobadas en WhatsApp Manager — ver docs/WHATSAPP_HAZLO_AGENTS.md
# HAZLO_WHATSAPP_USE_TEMPLATES=true
# WHATSAPP_TEMPLATE_LANGUAGE=es
# HAZLO_WA_TMPL_RECOVERY_1=hazlo_recovery_1
# HAZLO_WA_TMPL_RECOVERY_2=hazlo_recovery_2
# HAZLO_WA_TMPL_GROWTH_UPSELL=hazlo_growth_upsell
# Teléfono visible en plantilla recovery_2 (variable {{3}})
# HAZLO_RECOVERY_WA_SUPPORT_PHONE=+525512345678

# =============================================================================
# Vitalis — Intake / Meta / Qualifier
# =============================================================================
INTAKE_WEBHOOK_SECRET=
META_INTAKE_VERIFY_TOKEN=
META_APP_SECRET=
VITALIS_INTAKE_SLACK_WEBHOOK_URL=
VITALIS_NAVIGATOR_EMAIL=
# OPS_EMAIL=

QUALIFIER_FORM_URL_DEFAULT=
QUALIFIER_FORM_URL_DIABETES=
QUALIFIER_FORM_URL_ONCOLOGY=
QUALIFIER_FORM_URL_CARDIO=
QUALIFIER_CRON_SECRET=
QUALIFIER_WEBHOOK_SECRET=

# =============================================================================
# Vitalis — B2C cadence + prescreen links (Cloudflare cron → /api/vitalis/cadence/tick)
# =============================================================================
# URL del formulario/prescreen en emails y plantillas WhatsApp (prioridad sobre NEXT_PUBLIC_APP_URL/onboarding)
# VITALIS_PRESCREEN_URL=https://tudominio.com/onboarding
# NEXT_PUBLIC_VITALIS_PRESCREEN_URL=
# Nombres de plantillas aprobadas en WhatsApp Manager (defaults en lib/vitalis/cadence-b2c.ts)
# VITALIS_WA_TEMPLATE_WELCOME=vitalis_welcome_prescreen
# VITALIS_WA_TEMPLATE_VISIT_REMINDER=vitalis_visit_reminder_24h

# =============================================================================
# Vitalis — Scheduler / enlaces
# =============================================================================
# APP_URL o NEXT_PUBLIC_APP_URL (base para links en correos)
# Destinatario por defecto en UI (Contacts) si el contacto no tiene email
# NEXT_PUBLIC_DEFAULT_REPORT_EMAIL=ops@vilo.example
# SCHEDULER_DISPLAY_TZ=America/Mexico_City
# SCHEDULER_CONFIRM_SECRET=
# VITALIS_SATISFACTION_SURVEY_URL=

# =============================================================================
# HazloAsíYa — Growth / recovery / validator (opcional)
# =============================================================================
# HAZLO_GROWTH_BASE_URL=
# HAZLO_GROWTH_OFFER_PATH=/offers/{{slug}}
# HAZLO_PAYMENT_UPDATE_URL=
# HAZLO_SUPPORT_URL=
# HAZLO_CHURN_SURVEY_URL=
# HAZLO_RECOVERY_DISCOUNT_CODE=RECOVERY10
# HAZLO_VALIDATOR_EXAMPLE_BASE_URL=

# =============================================================================
# HazloAsíYa — Stripe (legado / dual con Square; metadata submission_id)
# =============================================================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# =============================================================================
# Otros agentes ViloOS
# =============================================================================
# ORCHESTRATOR_WORKLOAD_TASK_LIMIT=10
# TRIAGE_BURST_THRESHOLD=5
# TRIAGE_MIN_INTERVAL_HOURS=1
